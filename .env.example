# ============================================
# Zylith — Environment Variables
# ============================================
# Copy to .env.local and fill in values.
# For GitHub: set as repository secrets with `gh secret set`

# --- Shared ---
STARKNET_RPC_URL=https://starknet-sepolia.g.alchemy.com/starknet/version/rpc/v0_8/<API_KEY>
ADMIN_ADDRESS=0xYOUR_ADMIN_ADDRESS

# --- Deploy Scripts ---
STARKNET_ACCOUNT=scripts/starknet-account/account.json
STARKNET_KEYSTORE=scripts/starknet-account/keystore.json
STARKNET_KEYSTORE_PASSWORD=

# --- ASP Server ---
ASP_HOST=127.0.0.1
ASP_PORT=3001
ADMIN_PRIVATE_KEY=0xYOUR_PRIVATE_KEY
KEYSTORE_PATH=../scripts/starknet-account/keystore.json
KEYSTORE_PASSWORD=
COORDINATOR_ADDRESS=
POOL_ADDRESS=

# --- Frontend ---
VITE_CAVOS_APP_ID=
VITE_STARKNET_NETWORK=sepolia
VITE_ASP_URL=http://localhost:3001
VITE_CHAIN_ID=SN_SEPOLIA
